# MCP Server
PORT=3000
HOST=0.0.0.0

# Embeddings (OpenAI-compatible endpoint)
EMBEDDINGS_API_KEY=sk-...
EMBEDDINGS_API_BASE=https://api.openai.com/v1
EMBEDDINGS_MODEL=text-embedding-3-small

# Optional: API key to protect the MCP endpoint
MCP_API_KEY=

# Path to a cardano-dev-skills checkout. The skills repo is the canonical
# source of doc registry + vendored content + skill workflows. Default
# resolves to a sibling clone (../cardano-dev-skills).
SKILLS_PATH=../cardano-dev-skills
