{
  "name": "cardano-unified-mcp-server",
  "version": "0.1.0",
  "description": "Unified MCP server for building on Cardano — docs, tools, and chain queries in one place",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "ingest": "tsx src/ingest/cli.ts",
    "typecheck": "tsc --noEmit",
    "eval": "tsx eval/run.ts",
    "eval:snapshot": "tsx eval/run.ts --snapshot",
    "eval:keyword": "tsx eval/run.ts --keyword-only"
  },
  "keywords": [
    "cardano",
    "mcp",
    "model-context-protocol",
    "llm"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.0",
    "express": "^5.1.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "openai": "^4.80.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sqlite-vec": "^0.1.9",
    "strip-markdown": "^6.0.0",
    "unified": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
